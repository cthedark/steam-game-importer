{
  "name": "steam-game-importer",
  "version": "1.0.0",
  "description": "Wizard-style tool to import a single non-Steam game into your Steam library with artwork from SteamGridDB",
  "license": "GPL-3.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "steam-game-importer": "bin/steam-game-importer"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@node-steam/vdf": "^2.2.0",
    "chalk": "^5.3.0",
    "crc": "^4.3.2",
    "fs-extra": "^11.2.0",
    "fuzzysort": "^3.1.0",
    "glob": "^11.0.0",
    "inquirer": "^9.2.23",
    "node-fetch": "^3.3.2",
    "steam-shortcut-editor": "^3.1.3",
    "steamgriddb": "^2.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^22.5.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  }
}
